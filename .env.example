# ---- Database (Supabase Postgres) ----
# Pooled connection (PgBouncer) used by the app at runtime:
DATABASE_URL="postgresql://USER:PASSWORD@HOST:6543/postgres?pgbouncer=true"
# Direct connection used by Prisma for migrations:
DIRECT_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# ---- Auth.js (NextAuth v5) ----
# Generate with: openssl rand -base64 32
AUTH_SECRET=""

AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# ---- News source (currentsapi.services) ----
CURRENTS_API_KEY=""

# Authorizes the scheduled /api/sync cron call. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64url'))"
CRON_SECRET=""

# ---- Transactional email (brevo.com) ----
# Used to send account-verification emails. Free tier: 300 emails/day.
# Leave BREVO_API_KEY empty in dev to log verification links to the console.
BREVO_API_KEY=""
# Must be a sender address verified in your Brevo account.
EMAIL_FROM="no-reply@example.com"
EMAIL_FROM_NAME="Newsera"

# ---- App ----
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
