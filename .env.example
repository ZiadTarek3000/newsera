# ---------------------------------------------------------------------------
# Newsera environment variables. Copy to `.env` and fill in real values.
# ---------------------------------------------------------------------------

# --- Database (PostgreSQL) ---
DATABASE_URL="postgresql://user:password@host:5432/newsera"
# Direct (non-pooled) connection, used by Prisma migrations.
DIRECT_URL="postgresql://user:password@host:5432/newsera"

# --- Auth.js / NextAuth ---
# Generate with: npx auth secret   (or: openssl rand -base64 33)
AUTH_SECRET="replace-with-a-long-random-string"

# Optional. Auto-detected from the request host when omitted (trustHost is on).
# Set in production ONLY if the callback origin is being computed incorrectly
# (e.g. custom domain behind a proxy). Must be the site's external origin:
#   AUTH_URL="https://your-production-domain.com"

# --- Google OAuth ---
# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client.
# The provider auto-enables only when BOTH values are set (see hasGoogle in
# lib/env.ts). Register these redirect URIs on the client (see docs/AUTH_SETUP.md):
#   Production:  https://newsera-vert.vercel.app/api/auth/callback/google
#   Local dev:   http://localhost:3000/api/auth/callback/google   (port is pinned)
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# --- News ingestion (Currents API) ---
CURRENTS_API_KEY=""
# Bearer secret required by the /api/sync cron route.
CRON_SECRET=""

# --- Transactional email (Brevo) ---
BREVO_API_KEY=""
EMAIL_FROM="no-reply@newsera.app"
EMAIL_FROM_NAME="Newsera"

# --- Public site URL (used for canonical links, sitemap, OG metadata) ---
# Dev: http://localhost:3000   Prod: your real https origin.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
